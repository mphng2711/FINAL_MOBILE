<?xml version="1.0" encoding="utf-8"?>
<!-- item_promotion.xml — một thẻ khuyến mãi -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_rounded"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- Header: Badge + Toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/promoCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_promo_tag"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:text="PUREPAW10"
            android:textColor="@color/white"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/promoDiscount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:paddingLeft="6dp"
            android:paddingRight="6dp"
            android:background="@drawable/bg_status_purple"
            android:text="-10%"
            android:textColor="#15236F"
            android:textSize="13sp"
            android:textStyle="bold" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <Switch
            android:id="@+id/promoToggle"
            android:layout_width="108dp"
            android:layout_height="52dp"
            android:checked="true"
            android:thumbTint="@color/primary_orange"
            android:trackTint="#E79B4C"
            tools:ignore="UseSwitchCompatOrMaterialXml" />

        <ImageView
            android:id="@+id/btnDeleteProduct"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_marginLeft="8dp"
            android:layout_marginRight="10dp"
            android:padding="5dp"
            android:background="@drawable/bg_status_red"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="@color/red_negative" />
    </LinearLayout>

    <!-- Mô tả -->
    <TextView
        android:id="@+id/promoDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Giảm 10% đơn đầu tiên"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:textStyle="bold" />
    <TextView
        android:id="@+id/promoDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Tối thểu 200.000đ"
        android:textColor="@color/text_primary"
        android:textSize="11sp" />

    <!-- Progress bar sử dụng -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ProgressBar
            android:id="@+id/promoProgress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="6dp"
            android:layout_weight="1"
            android:max="100"
            android:progress="65"
            android:progressTint="@color/primary_orange"
            android:progressBackgroundTint="@color/divider" />

        <TextView
            android:id="@+id/promoUsage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="162/100 lượt"
            android:textColor="@color/text_hint"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Thời hạn -->
    <TextView
        android:id="@+id/promoExpiry"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Hạn dùng: đến 30/06/2025"
        android:textColor="@color/text_hint"
        android:textSize="11sp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:background="@color/divider" />

</LinearLayout>
