<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card"
    android:orientation="horizontal"
    android:padding="14dp">

    <!-- Time column -->
    <TextView
        android:id="@+id/tvTime"
        android:layout_width="56dp"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:fontFamily="sans-serif-medium"
        android:text="09:00"
        android:textColor="@color/text_dark"
        android:textSize="14sp" />

    <!-- Card content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Row: icon + service name + status badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivServiceIcon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_spa" />

            <TextView
                android:id="@+id/tvServiceName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:text="Spa toàn thân"
                android:textColor="@color/text_dark"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge"
                android:paddingStart="10dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:text="Đã xác nhận"
                android:textColor="@color/badge_blue_text"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Row: owner + pet -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="13dp"
                android:layout_height="13dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_person" />

            <TextView
                android:id="@+id/tvOwnerPet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="Nguyễn Thị Mai · Mèo Anh lông ngắn"
                android:textColor="@color/text_gray"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Row: note -->
        <LinearLayout
            android:id="@+id/layoutNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="top"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="13dp"
                android:layout_height="13dp"
                android:layout_marginTop="2dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_pin" />

            <TextView
                android:id="@+id/tvNote"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:text="Mèo hay cắn, cần nhẹ nhàng"
                android:textColor="@color/note_orange"
                android:textStyle="italic"
                android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
