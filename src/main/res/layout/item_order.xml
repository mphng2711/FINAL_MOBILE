<?xml version="1.0" encoding="utf-8"?>
<!-- item_order.xml — một dòng đơn hàng trong RecyclerView -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:orientation="horizontal"
    android:paddingTop="13dp"
    android:paddingBottom="13dp"
    android:paddingLeft="22dp">

    <!-- Mã đơn / Số thứ tự -->
    <TextView
        android:id="@+id/orderIndex"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@drawable/bg_btn_orange"
        android:gravity="center"
        android:text="2847"
        android:textColor="#A65A12"
        android:textSize="10sp"
        android:textStyle="bold" />

    <!-- Thông tin đơn hàng -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/customerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nguyễn Thị Mai"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/productName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Royal Canin Adult Medium"
            android:textColor="@color/text_secondary"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/orderStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_green"
                android:paddingStart="8dp"
                android:paddingTop="2dp"
                android:paddingEnd="8dp"
                android:paddingBottom="2dp"
                android:text="Hoàn thành"
                android:textColor="#20897D"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/orderDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="19/06/2025"
                android:textColor="@color/text_hint"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Giá -->
    <TextView
        android:id="@+id/orderPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:text="450.000đ"
        android:textColor="@color/primary_orange"
        android:textSize="13sp"
        android:paddingRight="60dp"
        android:textStyle="bold" />

</LinearLayout>
