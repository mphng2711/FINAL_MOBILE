<?xml version="1.0" encoding="utf-8"?>
<!-- item_user.xml — một dòng người dùng trong RecyclerView -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_rounded"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <!-- Avatar -->
    <TextView
        android:id="@+id/userAvatar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_avatar_orange"
        android:gravity="center"
        android:text="M"
        android:layout_marginLeft="15dp"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- Thông tin user -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/userName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nguyễn Thị Mai"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/userPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="092 216 141"
            android:textColor="@color/text_secondary"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/userStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_green"
                android:padding="6dp"
                android:text="Hoạt động"
                android:textColor="@color/green_positive"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/userOrderCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="17 đơn"
                android:textColor="@color/text_hint"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Tổng chi -->
    <TextView
        android:id="@+id/userTotalSpend"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2.850.000đ"
        android:textColor="@color/primary_orange"
        android:textSize="14sp"
        android:paddingRight="40dp"
        android:textStyle="bold" />

</LinearLayout>
