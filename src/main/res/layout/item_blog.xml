<?xml version="1.0" encoding="utf-8"?>
<!-- item_blog.xml — một bài blog trong RecyclerView -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/bg_card_rounded"
    android:orientation="horizontal"
    android:padding="12dp">

    <!-- Ảnh thumbnail -->
    <ImageView
        android:id="@+id/blogThumbnail"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@drawable/bg_card_rounded"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_gallery" />

    <!-- Nội dung -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:paddingLeft="5dp"
        android:orientation="vertical">

        <!-- Tiêu đề -->
        <TextView
            android:id="@+id/blogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="5 loại thức ăn tốt nhất cho Golden Retriever"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- Mô tả -->
        <TextView
            android:id="@+id/blogExcerpt"
            android:layout_width="237dp"
            android:layout_height="30dp"
            android:layout_marginTop="3dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Golden Retriever cần được dinh dưỡng đặc biệt để duy trì sức khỏe tối ưu..."
            android:textColor="@color/text_secondary"
            android:textSize="11sp" />

        <!-- Meta: tác giả + ngày + trạng thái -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/blogAuthor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bs. Minh Tuấn"
                android:textColor="@color/text_hint"
                android:textSize="10sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:text="•"
                android:textColor="@color/text_hint"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/blogDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="14/08/2025"
                android:textColor="@color/text_hint"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/blogStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_green"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="Đã đăng"
                android:textColor="@color/green_positive"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>
    <ImageView
        android:id="@+id/btnDeleteProduct"
        android:layout_width="33dp"
        android:layout_height="33dp"
        android:padding="5dp"
        android:layout_marginRight="15dp"
        android:background="@drawable/bg_status_red_round"
        android:src="@android:drawable/ic_menu_delete"
        app:tint="@color/red_negative" />

</LinearLayout>
