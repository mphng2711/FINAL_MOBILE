<?xml version="1.0" encoding="utf-8"?>
<!-- layout_bottom_nav.xml — dùng chung qua <include> cho tất cả màn hình -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bottomNav"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:background="@color/white"
    android:elevation="8dp"
    android:orientation="horizontal"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <!-- Tab: Tổng quan -->
    <LinearLayout
        android:id="@+id/tabOverview"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/iconOverview"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@android:drawable/ic_menu_compass"
            app:tint="@color/text_secondary" />

        <TextView
            android:id="@+id/labelOverview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Tổng quan"
            android:textColor="@color/text_secondary"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Tab: Đơn hàng -->
    <LinearLayout
        android:id="@+id/tabOrders"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/iconOrders"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@mipmap/ic_tab_order"
            app:tint="@color/text_secondary" />

        <TextView
            android:id="@+id/labelOrders"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Đơn hàng"
            android:textColor="@color/text_secondary"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Tab: Sản phẩm -->
    <LinearLayout
        android:id="@+id/tabProducts"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/iconProducts"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@mipmap/ic_tab_product"
            app:tint="@color/text_secondary" />

        <TextView
            android:id="@+id/labelProducts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Sản phẩm"
            android:textColor="@color/text_secondary"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Tab booking -->
    <LinearLayout
        android:id="@+id/tabBooking"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/iconBooking"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@mipmap/ic_tab_booking"
            app:tint="@color/primary_orange" />

        <TextView
            android:id="@+id/labelBooking"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Đặt lịch"
            android:textColor="@color/primary_orange"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Tab: Thêm -->
    <LinearLayout
        android:id="@+id/tabMore"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/iconMore"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@android:drawable/ic_menu_more"
            app:tint="@color/text_secondary" />

        <TextView
            android:id="@+id/labelMore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Thêm"
            android:textColor="@color/text_secondary"
            android:textSize="10sp" />
    </LinearLayout>

</LinearLayout>
