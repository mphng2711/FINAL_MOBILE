<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Reused by the booking-success detail rows (icon + label/value column) -->
    <style name="SuccessDetailRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">12dp</item>
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="SuccessDetailIcon">
        <item name="android:layout_width">28dp</item>
        <item name="android:layout_height">28dp</item>
        <item name="android:layout_marginEnd">12dp</item>
        <item name="android:layout_gravity">top</item>
        <item name="android:background">@drawable/shape_circle</item>
        <item name="android:backgroundTint">@color/pp_light_beige</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="SuccessDetailTextColumn">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="SuccessDetailLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/pp_text_secondary</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="SuccessDetailValue">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/pp_text_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Reused by the profile menu rows and the appointment history list -->
    <style name="ProfileMenuCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
        <item name="cardBackgroundColor">@color/pp_surface</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="ProfileMenuRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:padding">12dp</item>
    </style>

    <style name="ProfileMenuIcon">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_marginEnd">16dp</item>
        <item name="android:background">@drawable/shape_rounded_10</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">20sp</item>
    </style>

    <style name="ProfileMenuTextColumn">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="ProfileMenuTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/pp_text_primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ProfileMenuSubtitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">2dp</item>
        <item name="android:textColor">@color/pp_text_secondary</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="ProfileMenuChevron">
        <item name="android:layout_width">20dp</item>
        <item name="android:layout_height">20dp</item>
        <item name="android:src">@drawable/ic_chevron_right</item>
    </style>

    <!-- Reused by the rating screen -->
    <style name="RatingStar">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginHorizontal">4dp</item>
        <item name="android:text">☆</item>
        <item name="android:textColor">#D0D0D0</item>
        <item name="android:textSize">36sp</item>
    </style>

    <style name="RatingTagChip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="android:textColor">@color/pp_text_secondary</item>
        <item name="android:checkable">true</item>
        <item name="chipBackgroundColor">@color/pp_chip_gray_bg</item>
    </style>

    <!-- Generic section heading reused across product/cart/checkout/spa/profile screens -->
    <style name="SectionTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">12dp</item>
        <item name="android:textColor">@color/pp_text_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Status badge pill reused by order history / order detail -->
    <style name="StatusBadge">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/shape_rounded_20</item>
        <item name="android:paddingHorizontal">8dp</item>
        <item name="android:paddingVertical">3dp</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Generic content card reused by order/checkout/contact/about/policy screens -->
    <style name="ContentCard" parent="Widget.MaterialComponents.CardView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="cardBackgroundColor">@color/pp_surface</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
    </style>

</resources>
