<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pp_background"
    android:orientation="vertical">

    <!-- Success header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.36"
        android:background="@color/pp_chip_green_bg"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="32dp">

        <FrameLayout
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:background="@drawable/shape_circle">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="✅"
                android:textSize="34sp" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Đặt lịch thành công!"
            android:textColor="@color/pp_success_dark"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="Xác nhận đã được gửi qua SMS và email của bạn"
            android:textColor="@color/pp_success"
            android:textSize="13sp" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.64">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="96dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/pp_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/shape_rounded_16_top"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="✂️ Spa &amp; Grooming"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/shape_rounded_20"
                            android:backgroundTint="#33FFFFFF"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="2dp"
                            android:text="SP240090"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            style="@style/SuccessDetailRow"
                            android:layout_marginTop="0dp">

                            <TextView style="@style/SuccessDetailIcon" android:text="🐾" />

                            <LinearLayout style="@style/SuccessDetailTextColumn">
                                <TextView style="@style/SuccessDetailLabel" android:text="Thú cưng" />
                                <TextView style="@style/SuccessDetailValue" android:text="Lucky (Poodle)" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout style="@style/SuccessDetailRow">

                            <TextView style="@style/SuccessDetailIcon" android:text="📅" />

                            <LinearLayout style="@style/SuccessDetailTextColumn">
                                <TextView style="@style/SuccessDetailLabel" android:text="Ngày &amp; Giờ" />
                                <TextView style="@style/SuccessDetailValue" android:text="Thứ 5, 19/06/2026 · 09:00 – 11:00" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout style="@style/SuccessDetailRow">

                            <TextView style="@style/SuccessDetailIcon" android:text="📍" />

                            <LinearLayout style="@style/SuccessDetailTextColumn">
                                <TextView style="@style/SuccessDetailLabel" android:text="Chi nhánh" />
                                <TextView style="@style/SuccessDetailValue" android:text="Q.1 – 45 Nguyễn Trãi" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout style="@style/SuccessDetailRow">

                            <TextView style="@style/SuccessDetailIcon" android:text="👤" />

                            <LinearLayout style="@style/SuccessDetailTextColumn">
                                <TextView style="@style/SuccessDetailLabel" android:text="Nhân viên" />
                                <TextView style="@style/SuccessDetailValue" android:text="Nguyễn Thị Lan" />
                            </LinearLayout>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="12dp"
                            android:background="@color/pp_divider" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Tổng thanh toán"
                                android:textColor="@color/pp_text_secondary"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="250.000đ"
                                android:textColor="@color/pp_primary"
                                android:textSize="18sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/shape_rounded_12_stroke"
                android:orientation="horizontal"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:text="ℹ️"
                    android:textSize="18sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Lưu ý trước khi đến"
                        android:textColor="@color/pp_note_text"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="· Đến trước giờ hẹn 10 phút\n· Mang theo sổ tiêm phòng của thú cưng\n· Liên hệ 1900 1234 nếu cần hỗ trợ"
                        android:textColor="@color/pp_note_text"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_done"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/pp_primary"
                android:text="🗓 Xem lịch hẹn của tôi"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
