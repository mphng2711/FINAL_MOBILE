<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pp_background"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/shape_circle"
            android:backgroundTint="@color/pp_chip_gray_bg"
            android:contentDescription="@null"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Chọn ngày giờ"
            android:textColor="@color/pp_text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp">

            <!-- Selected service summary -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/shape_rounded_16"
                android:backgroundTint="@color/pp_light_beige"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Dịch vụ đã chọn"
                        android:textColor="@color/pp_text_secondary"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Tắm gội thú cưng"
                        android:textColor="@color/pp_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="⏰ 45 phút"
                        android:textColor="@color/pp_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="120.000đ"
                    android:textColor="@color/pp_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Date selection -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/SectionTitle"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="Chọn ngày" />

                <TextView
                    android:id="@+id/btn_open_calendar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/shape_circle"
                    android:backgroundTint="@color/pp_chip_gray_bg"
                    android:gravity="center"
                    android:text="📅"
                    android:textSize="16sp" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chip_date_0"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/shape_rounded_14_stroke"
                        android:backgroundTint="@color/pp_primary"
                        android:gravity="center"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="14dp"
                        android:text="Hôm nay"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/chip_date_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/shape_rounded_14_stroke"
                        android:gravity="center"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="14dp"
                        android:text="Thứ 3"
                        android:textColor="@color/pp_text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/chip_date_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/shape_rounded_14_stroke"
                        android:gravity="center"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="14dp"
                        android:text="Thứ 4"
                        android:textColor="@color/pp_text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/chip_date_3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/shape_rounded_14_stroke"
                        android:gravity="center"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="14dp"
                        android:text="Thứ 5"
                        android:textColor="@color/pp_text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/chip_date_4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/shape_rounded_14_stroke"
                        android:gravity="center"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="14dp"
                        android:text="Thứ 6"
                        android:textColor="@color/pp_text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/chip_date_5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/shape_rounded_14_stroke"
                        android:gravity="center"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="14dp"
                        android:text="Thứ 7"
                        android:textColor="@color/pp_text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/chip_date_6"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/shape_rounded_14_stroke"
                        android:gravity="center"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="14dp"
                        android:text="CN"
                        android:textColor="@color/pp_text_primary"
                        android:textSize="14sp" />

                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/tv_selected_date_full"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Đã chọn: Hôm nay"
                android:textColor="@color/pp_text_secondary"
                android:textSize="13sp" />

            <!-- Time selection -->
            <TextView
                style="@style/SectionTitle"
                android:layout_marginTop="24dp"
                android:text="Chọn khung giờ" />

            <com.google.android.material.chip.ChipGroup
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:chipSpacingHorizontal="10dp"
                app:chipSpacingVertical="10dp"
                app:singleSelection="false">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_time_0900"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:checked="true"
                    android:text="09:00"
                    android:textColor="@color/white"
                    app:chipBackgroundColor="@color/pp_primary"
                    app:chipCornerRadius="12dp"
                    app:chipStrokeWidth="0dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_time_1030"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="false"
                    android:enabled="false"
                    android:text="10:30"
                    android:textColor="@color/pp_text_secondary"
                    app:chipBackgroundColor="@color/pp_chip_gray_bg"
                    app:chipCornerRadius="12dp"
                    app:chipStrokeWidth="0dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_time_1300"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="13:00"
                    android:textColor="@color/pp_text_primary"
                    app:chipBackgroundColor="@color/pp_surface"
                    app:chipCornerRadius="12dp"
                    app:chipStrokeColor="@color/pp_outline"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_time_1430"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="14:30"
                    android:textColor="@color/pp_text_primary"
                    app:chipBackgroundColor="@color/pp_surface"
                    app:chipCornerRadius="12dp"
                    app:chipStrokeColor="@color/pp_outline"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_time_1600"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="false"
                    android:enabled="false"
                    android:text="16:00"
                    android:textColor="@color/pp_text_secondary"
                    app:chipBackgroundColor="@color/pp_chip_gray_bg"
                    app:chipCornerRadius="12dp"
                    app:chipStrokeWidth="0dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_time_1730"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="17:30"
                    android:textColor="@color/pp_text_primary"
                    app:chipBackgroundColor="@color/pp_surface"
                    app:chipCornerRadius="12dp"
                    app:chipStrokeColor="@color/pp_outline"
                    app:chipStrokeWidth="1dp" />

            </com.google.android.material.chip.ChipGroup>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_next"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="96dp"
        android:backgroundTint="@color/pp_primary"
        android:text="Tiếp tục"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="12dp" />

</LinearLayout>
