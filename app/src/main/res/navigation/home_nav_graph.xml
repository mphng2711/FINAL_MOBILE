<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/home_nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.purepawapp.ui.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_homeFragment_to_blogListFragment"
            app:destination="@id/blogListFragment" />
    </fragment>

    <fragment
        android:id="@+id/blogListFragment"
        android:name="com.example.purepawapp.ui.blog.BlogListFragment"
        android:label="Blog"
        tools:layout="@layout/fragment_blog_list">
        <action
            android:id="@+id/action_blogListFragment_to_blogDetailFragment"
            app:destination="@id/blogDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/blogDetailFragment"
        android:name="com.example.purepawapp.ui.blog.BlogDetailFragment"
        android:label="Blog Detail"
        tools:layout="@layout/fragment_blog_detail">
        <argument
            android:name="blogId"
            app:argType="string" />
    </fragment>

</navigation>
